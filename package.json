{
  "name": "execution-apis",
  "version": "0.0.0",
  "description": "Collection of JSON-RPC APIs provided by Ethereum 1.0 clients",
  "main": "index.js",
  "engines": {"node": ">=22.0.0", "npm": ">=10.0.0"},
  "scripts": {
    "build": "make build",
    "build:spec": "make build",
    "build:test": "make test",
    "build:docs": "npm run build:spec && npm run build:docs:core",
    "build:docs:core": "npm run docs:copy && npm run build:docusaurus",
    "docs:copy": "cp README.md ./docs-api/docs/quickstart.md",
    "start": "docusaurus start",
    "serve": "docusaurus serve",
    "deploy:hardhat": "hardhat run scripts/deploy.js --network hardhat",
    "deploy:base": "hardhat run scripts/deploy.js --network base",
    "deploy:mainnet": "hardhat run scripts/deploy.js --network mainnet",
    "agent:execute": "node agent/execute.js",
    "test": "hardhat test",
    "compile": "hardhat compile",
    "verify": "hardhat verify"
  },
  "license": "CC0-1.0",
  "dependencies": {
    "@docusaurus/core": "^3.9.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "hardhat": "^2.19.4",
    "ethers": "^6.10.0",
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "chai": "^4.3.10"
  }
}